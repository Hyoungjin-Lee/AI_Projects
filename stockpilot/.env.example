# ============================================================
# 한국투자증권 Open API 자격증명 템플릿
# ============================================================
# 이 파일을 복사해 .env 로 이름을 바꾼 뒤 실제 값을 채우세요.
# 또는 keychain_manager.py --reset 을 실행해 Keychain에 직접 저장하세요.
# .env 파일은 절대 Git에 올리지 마세요 (.gitignore에 포함됨).
# ============================================================

# 앱 키 / 시크릿 (KIS Developers 포털 https://apiportal.koreainvestment.com 에서 발급)
KIS_APP_KEY=여기에_앱키_입력
KIS_APP_SECRET=여기에_앱시크릿_입력

# 계좌번호 — 형식: 8자리-2자리 (예: 12345678-01)
KIS_ACCOUNT_NO=12345678-01

# MTS/홈페이지 로그인 ID (관심종목 동기화에 필요)
KIS_HTS_ID=여기에_HTS_ID_입력

# 투자 환경 — real 고정 (모의투자 미사용)
KIS_ENV=real

# ============================================================
# 실주문 안전장치
# 아래 변수가 없으면 실제 주문이 전송되지 않습니다.
# 실주문을 허용하려면 아래 주석을 해제하고 1로 설정하세요.
# ============================================================
# KIS_ALLOW_LIVE_ORDER=1

# ============================================================
# 텔레그램 봇 설정
# BotFather에서 봇 생성 후 토큰 발급 → setup_telegram.py 실행
# ============================================================
TELEGRAM_BOT_TOKEN=여기에_봇_토큰_입력
TELEGRAM_CHAT_ID=여기에_chat_id_입력
